---
const steps = [
  {
    number: "01",
    title: "Free Discovery Call",
    description:
      "In unserem ersten Kennlern­gespraech finden wir heraus, wo aktuell deine groessten Herausforderungen sind, was du wirklich brauchst und wie ich dich am besten unterstuetzen kann."
  },
  {
    number: "02",
    title: "Strategie & Fahrplan",
    description:
      "Danach bauen wir einen klaren Plan mit Inhalt, Struktur und Design-Richtung. Du weisst genau, was als naechstes passiert und wie wir Schritt fuer Schritt zur Website kommen."
  }
];
---

<section class="process-wrap" data-dark data-process-wrap>
  <div class="process-sticky">
    <div class="process-intro rv">
      <span class="process-kicker">So laeuft es ab</span>
      <h2>Ein klarer Prozess. Ohne Chaos.</h2>
    </div>

    <div class="process-stage" data-process-stage>
      {steps.map((step, idx) => (
        <article class="process-card" data-process-card data-step={idx + 1}>
          <span class="process-no">{step.number}</span>
          <h3>{step.title}</h3>
          <p>{step.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .process-wrap {
    position: relative;
    min-height: 100vh;
    background:
      radial-gradient(circle at 20% 10%, rgba(202, 255, 0, 0.08), transparent 35%),
      radial-gradient(circle at 80% 20%, rgba(120, 170, 255, 0.08), transparent 36%),
      linear-gradient(180deg, #121212 0%, #0c0c0c 100%);
    color: #f4f2ec;
    overflow: clip;
  }

  .process-sticky {
    position: relative;
    min-height: 100vh;
    display: grid;
    place-items: center;
    padding: 7rem 1.3rem 4rem;
  }

  .process-intro {
    position: absolute;
    top: clamp(2.8rem, 5vw, 4.8rem);
    left: 50%;
    transform: translateX(-50%);
    width: min(900px, 92vw);
    text-align: center;
    z-index: 4;
  }

  .process-kicker {
    display: inline-block;
    font-family: var(--font-display);
    font-size: 0.58rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(244, 242, 236, 0.65);
    margin-bottom: 0.6rem;
  }

  .process-intro h2 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 6vw, 3.4rem);
    letter-spacing: -0.03em;
    line-height: 0.95;
    margin: 0;
  }

  .process-stage {
    position: relative;
    width: min(680px, 92vw);
    height: min(52vh, 420px);
    will-change: transform;
  }

  .process-card {
    position: absolute;
    inset: 0;
    margin: auto;
    width: min(620px, 100%);
    min-height: 250px;
    border-radius: 24px;
    padding: clamp(1.2rem, 2.1vw, 1.8rem);
    backdrop-filter: blur(24px) saturate(130%);
    -webkit-backdrop-filter: blur(24px) saturate(130%);
    border: 1px solid rgba(255, 255, 255, 0.23);
    background:
      linear-gradient(120deg, rgba(255, 255, 255, 0.17), rgba(255, 255, 255, 0.06)),
      rgba(22, 22, 22, 0.5);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.28),
      inset 0 -20px 50px rgba(255, 255, 255, 0.03),
      0 26px 90px rgba(0, 0, 0, 0.45);
    transform-origin: center center;
    transition: box-shadow 0.35s ease;
    will-change: transform, opacity, filter;
  }

  .process-card.is-animating {
    transition: transform 0.75s cubic-bezier(0.4, 0, 0.2, 1),
                opacity 0.75s cubic-bezier(0.4, 0, 0.2, 1),
                filter 0.75s cubic-bezier(0.4, 0, 0.2, 1),
                box-shadow 0.35s ease;
  }

  .process-card:hover {
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.3),
      inset 0 -20px 50px rgba(255, 255, 255, 0.05),
      0 30px 100px rgba(0, 0, 0, 0.5);
  }

  .process-card[data-step="1"] {
    z-index: 3;
  }

  .process-card[data-step="2"] {
    z-index: 2;
    opacity: 0;
    transform: translate3d(0, 240px, 0) scale(0.72);
    filter: blur(4.6px);
  }

  .process-no {
    display: inline-block;
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 5vw, 2.5rem);
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.03em;
    color: rgba(202, 255, 0, 0.92);
    margin-bottom: 1.05rem;
  }

  .process-card h3 {
    font-family: var(--font-display);
    font-size: clamp(1.15rem, 2.8vw, 1.65rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin: 0 0 0.9rem;
  }

  .process-card p {
    margin: 0;
    max-width: 52ch;
    color: rgba(244, 242, 236, 0.8);
    font-size: clamp(0.9rem, 1.35vw, 1rem);
    line-height: 1.65;
  }

  @media (max-width: 820px) {
    .process-wrap {
      min-height: 100vh;
    }

    .process-stage {
      height: min(50vh, 360px);
    }

    .process-card {
      min-height: 240px;
      border-radius: 20px;
    }
  }
</style>
