---
const services = [
  {
    number: "01",
    title: "Deine Website, von Grund auf",
    tags: ["Design", "Entwicklung"],
    description:
      "Keine Templates, kein Baukasten. Alles wird auf dich und dein Studio zugeschnitten - deine Farben, deine Sprache, deine Energie. Das Ergebnis ist eine Website die sich sofort wie deine anfuehlt.",
    list: ["Individuelles Design", "Responsive fuer alle Geraete", "Animationen & Custom Cursor", "Kontaktformular via Tally", "Schnelles Hosting inklusive"]
  },
  {
    number: "02",
    title: "Galerie die sich selbst aufbaut",
    tags: ["Portfolio", "Automatisiert"],
    description:
      "Du pflegst nur die Bilder. Fuer jede Galerie-Kategorie entsteht automatisch eine eigene optimierte Seite. Neue Kategorie hinzufuegen bedeutet eine Datei anlegen - fertig.",
    list: ["Unbegrenzte Kategorien", "Seiten entstehen automatisch", "Bilder laden blitzschnell", "Eigene SEO pro Kategorie", "Lightbox inklusive"]
  },
  {
    number: "03",
    title: "Kuemmere dich um nichts",
    tags: ["Hosting", "Support"],
    description:
      "Ich richte alles ein. Domain, Hosting, SSL - du musst nichts wissen. Kleine Aenderungen sind inklusive, ich bin per WhatsApp erreichbar.",
    list: ["Komplettes Hosting-Setup", "Domain-Konfiguration", "Kleine Aenderungen inklusive", "Erreichbar per WhatsApp", "Minimale laufende Kosten"]
  }
];
---

<section class="border-t border-blk/10 bg-w py-32" id="leistungen">
  <div class="mx-auto max-w-7xl px-10">
    <div class="rv mb-5 flex items-center gap-3 font-display text-[.56rem] font-bold uppercase tracking-[.28em] text-grey before:h-[2px] before:w-6 before:bg-acid before:content-['']">Leistungen</div>
    <h2 class="rv d1 font-display text-[clamp(2rem,4vw,3.8rem)] font-extrabold uppercase tracking-[-.03em] leading-[.93] text-blk">
      Was ich fuer<br /><em class="mt-0 block font-italic text-[.82em] font-normal normal-case text-grey">dich baue</em>
    </h2>

    <div class="rv d2 mt-16">
      {services.map((service) => (
        <div class="group overflow-hidden border-t border-blk/10 last:border-b" data-accord>
          <div class="grid cursor-none grid-cols-[60px_1fr_auto_44px] items-center gap-8 py-6 accord-head">
            <span class="font-display text-[.55rem] font-bold uppercase tracking-[.25em] text-w3">{service.number}</span>
            <span class="font-display text-[clamp(1.2rem,2.5vw,1.9rem)] font-extrabold uppercase tracking-[-.02em] text-blk transition group-[.open]:text-blk">{service.title}</span>
            <div class="flex flex-wrap justify-end gap-2">
              {service.tags.map((tag) => <span class="border border-w3 px-2 py-1 font-display text-[.46rem] font-semibold uppercase tracking-[.16em] text-grey transition group-[.open]:border-blk/20 group-[.open]:text-blk">{tag}</span>)}
            </div>
            <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full border border-blk/15 text-[.9rem] text-blk transition duration-500 ease-[cubic-bezier(.16,1,.3,1)] group-[.open]:rotate-45 group-[.open]:border-blk group-[.open]:bg-blk group-[.open]:text-acid">+</div>
          </div>
          <div class="h-0 overflow-hidden transition-[height] duration-500 ease-[cubic-bezier(.16,1,.3,1)] accord-body">
            <div class="grid grid-cols-[60px_1fr_1fr] gap-10 pb-10 accord-inner">
              <div></div>
              <p class="text-[.9rem] font-light leading-[1.85] text-grey">{service.description}</p>
              <ul class="flex list-none flex-col gap-2">
                {service.list.map((item) => <li class="flex items-center gap-2.5 font-display text-[.58rem] font-semibold uppercase tracking-[.1em] text-grey before:content-['→'] before:text-blk/40">{item}</li>)}
              </ul>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
