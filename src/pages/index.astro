---
import "../styles/global.css"
import Navigation from "./components/Navigation.astro";
import Ticker from "./components/Ticker.astro";
import Grain from "./components/Grain.astro";
import WhyMe from "./components/why-me.astro";
---
<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>WebWerkstattWalther — Websites für Fotografen</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=Playfair+Display:ital,wght@1,400;1,500&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/lenis@1.1.14/dist/lenis.min.js"></script>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{overflow-x:hidden}
:root{
  --w:#F4F2EC;--w2:#E8E4DB;--w3:#D0CCC2;
  --blk:#111110;--blk2:#1C1C1A;
  --grey:#888580;--acid:#CAFF00;--acid2:#B8EE00;
  --display:'Syne',sans-serif;
  --italic:'Playfair Display',Georgia,serif;
  --body:'DM Sans',system-ui,sans-serif;
}
::-webkit-scrollbar{width:3px}
::-webkit-scrollbar-track{background:var(--w)}
::-webkit-scrollbar-thumb{background:var(--blk)}

body{cursor:none;background:var(--w);color:var(--blk);font-family:var(--body);font-weight:300;line-height:1.6;overflow-x:hidden}

/* ── CURSOR ── */
#cd{
  position:fixed;top:0;left:0;width:10px;height:10px;
  background:var(--acid);border-radius:50%;
  pointer-events:none;z-index:9999;
  transform:translate(-50%,-50%);
  mix-blend-mode:difference;
  transition:width .2s,height .2s;
}
#cr{
  position:fixed;top:0;left:0;width:36px;height:36px;
  border:1.5px solid var(--blk);border-radius:50%;
  pointer-events:none;z-index:9998;
  transform:translate(-50%,-50%);
  transition:width .28s,height .28s,opacity .28s,border-color .3s;
  opacity:.3;
}
body.on-dark #cr{border-color:rgba(244,242,236,.45);opacity:.35}
body.ch #cd{width:5px;height:5px}
body.ch #cr{width:52px;height:52px;opacity:.12}
body.cl #cd{width:32px;height:32px;opacity:.15}
body.cl #cr{width:36px;height:36px;opacity:1}
body.on-dark.cl #cr{border-color:var(--acid)}



/* ── HERO ── */
.hero{min-height:100svh;display:grid;grid-template-columns:1fr 1fr;overflow:hidden;padding-top:5rem}
.hero-left{display:flex;flex-direction:column;justify-content:center;padding:4rem 3rem 4rem 2.5rem;border-right:1px solid rgba(17,17,16,.08);position:relative;z-index:1}
.hero-eyebrow{font-family:var(--display);font-size:.58rem;font-weight:700;letter-spacing:.28em;text-transform:uppercase;color:var(--grey);display:flex;align-items:center;gap:.7rem;margin-bottom:1.8rem;opacity:0;animation:ain .5s .15s forwards}
.hero-eyebrow::before{content:'';width:28px;height:2px;background:var(--acid)}
.hero-h{font-family:var(--display);font-size:clamp(2.8rem,5.5vw,5.2rem);font-weight:800;line-height:.92;letter-spacing:-.03em;text-transform:uppercase;color:var(--blk)}
.hero-h em{font-family:var(--italic);font-style:italic;text-transform:none;font-weight:400;letter-spacing:-.01em;color:var(--blk);display:block;font-size:.78em;margin-top:.12em}
.hl{overflow:hidden;display:block}
.hli{display:block;transform:translateY(115%);animation:up .8s cubic-bezier(.16,1,.3,1) forwards}
.hl:nth-child(1) .hli{animation-delay:.3s}
.hl:nth-child(2) .hli{animation-delay:.44s}
.hl:nth-child(3) .hli{animation-delay:.58s}
.hl:nth-child(4) .hli{animation-delay:.7s}
.hero-sub{font-size:.95rem;font-weight:300;line-height:1.8;color:var(--grey);max-width:420px;margin-top:1.8rem;opacity:0;animation:ain .7s .9s forwards}
.hero-acts{display:flex;align-items:center;gap:1.2rem;margin-top:2.2rem;flex-wrap:wrap;opacity:0;animation:ain .7s 1.05s forwards}
.btn-solid{font-family:var(--display);font-size:.6rem;font-weight:700;letter-spacing:.2em;text-transform:uppercase;background:var(--blk);color:var(--acid);padding:.9rem 2rem;text-decoration:none;cursor:none;display:inline-block;transition:background .2s,transform .18s}
.btn-solid:hover{background:var(--blk2);transform:translateY(-2px)}
.btn-line{font-family:var(--display);font-size:.6rem;font-weight:600;letter-spacing:.2em;text-transform:uppercase;color:var(--blk);text-decoration:none;cursor:none;display:inline-flex;align-items:center;gap:.6rem;border-bottom:1px solid rgba(17,17,16,.2);padding-bottom:2px;transition:border-color .2s}
.btn-line:hover{border-color:var(--blk)}
.btn-line::after{content:'→';transition:transform .2s}
.btn-line:hover::after{transform:translateX(4px)}
.hero-bottom-strip{position:absolute;bottom:2.5rem;left:2.5rem;right:3rem;display:flex;gap:3rem;align-items:flex-end;opacity:0;animation:ain .6s 1.3s forwards}
.hero-stat-n{font-family:var(--display);font-size:1.5rem;font-weight:800;color:var(--blk);letter-spacing:-.02em;display:block}
.hero-stat-l{font-size:.56rem;font-weight:400;letter-spacing:.12em;text-transform:uppercase;color:var(--grey);display:block;margin-top:.1rem}

/* ── DRIFT GRID (hero right) ── */
.hero-right{position:relative;overflow:hidden;background:var(--blk)}
.pgrid-wrap{
  position:absolute;inset:-60px;
  /* oversized so drift never reveals edges */
}
.pgrid{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  grid-template-rows:repeat(5,200px);
  gap:4px;
  width:100%;height:100%;
  animation:drift 14s ease-in-out infinite alternate;
}
@keyframes drift{
  0%  {transform:translate(40px,-40px)}
  100%{transform:translate(-40px,40px)}
}
.pgrid-item{overflow:hidden;position:relative;background:var(--blk2)}
.pgrid-item.span2{grid-row:span 2}
.tile-overlay{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:.4rem}
.tile-cat{font-family:var(--display);font-size:.52rem;font-weight:700;letter-spacing:.22em;text-transform:uppercase;color:rgba(244,242,236,.2)}
.tile-name{font-family:var(--italic);font-style:italic;font-size:1.4rem;font-weight:400;color:rgba(244,242,236,.1);text-align:center}
/* varied dark tile colors */
.t1{background:linear-gradient(145deg,#1e1612,#0e0c0a)}
.t2{background:linear-gradient(145deg,#0e1218,#080c10)}
.t3{background:linear-gradient(145deg,#181210,#100c08)}
.t4{background:linear-gradient(145deg,#12100e,#0a0808)}
.t5{background:linear-gradient(145deg,#101418,#080a0e)}
.t6{background:linear-gradient(145deg,#161210,#0c0a08)}
.t7{background:linear-gradient(145deg,#181614,#100e0c)}
.t8{background:linear-gradient(145deg,#0c1016,#080c10)}
.t9{background:linear-gradient(145deg,#14100e,#0c0808)}
.t10{background:linear-gradient(145deg,#161814,#0e100c)}
.t11{background:linear-gradient(145deg,#181210,#100c08)}
.t12{background:linear-gradient(145deg,#0e1214,#08090c)}
/* subtle inner glow on each tile */
.pgrid-item::after{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 35% 35%,rgba(255,255,255,.04) 0%,transparent 65%);pointer-events:none}
.pgrid-label{position:absolute;bottom:.7rem;left:.8rem;font-family:var(--display);font-size:.45rem;font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:rgba(244,242,236,.0);background:rgba(17,17,16,.6);backdrop-filter:blur(6px);padding:.22rem .55rem;transition:color .25s}
.pgrid-item:hover .pgrid-label{color:rgba(244,242,236,.7)}


/* ── SECTION BASE ── */
.s{padding:8rem 0;border-top:1px solid rgba(17,17,16,.07)}
.s-in{max-width:1280px;margin:0 auto;padding:0 2.5rem}
.s-tag{font-family:var(--display);font-size:.56rem;font-weight:700;letter-spacing:.28em;text-transform:uppercase;color:var(--grey);display:flex;align-items:center;gap:.7rem;margin-bottom:1.2rem}
.s-tag::before{content:'';width:24px;height:2px;background:var(--acid)}
.s-h{font-family:var(--display);font-size:clamp(2rem,4vw,3.8rem);font-weight:800;text-transform:uppercase;letter-spacing:-.03em;line-height:.93;color:var(--blk)}
.s-h em{font-family:var(--italic);font-style:italic;text-transform:none;font-weight:400;font-size:.82em;color:var(--grey);display:block}

/* ── BENEFITS — dark premium cards ── */
.benefits{background:var(--w2)}
.ben-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-top:4rem}

.ben-card{
  position:relative;overflow:hidden;
  border-radius:16px;
  background:#0f0e0c;
  padding:0;
  min-height:420px;
  display:flex;flex-direction:column;
  cursor:none;
  transition:transform .4s cubic-bezier(.16,1,.3,1);
}
.ben-card:hover{transform:translateY(-4px)}

/* dot-grid overlay like in the reference */
.ben-card::before{
  content:'';position:absolute;inset:0;z-index:1;
  background-image:radial-gradient(circle,rgba(255,255,255,.12) 1px,transparent 1px);
  background-size:22px 22px;
  mask-image:radial-gradient(ellipse 90% 90% at 50% 50%,#000 30%,transparent 100%);
  pointer-events:none;
}

/* top glow */
.ben-glow{
  position:absolute;top:-60px;left:50%;transform:translateX(-50%);
  width:280px;height:280px;
  border-radius:50%;
  pointer-events:none;z-index:2;
  opacity:.55;
  filter:blur(50px);
}
.ben-card:nth-child(1) .ben-glow{background:radial-gradient(circle,#3a5aff,transparent)}
.ben-card:nth-child(2) .ben-glow{background:radial-gradient(circle,#c8922a,transparent)}
.ben-card:nth-child(3) .ben-glow{background:radial-gradient(circle,#2a8a5a,transparent)}

/* the visual area (top ~55%) */
.ben-visual{
  position:relative;z-index:3;
  flex:1;
  display:flex;align-items:center;justify-content:center;
  padding:2.5rem 2rem 1rem;
}

/* card 1 visual: browser mockup with star rating */
.mock-browser{
  width:100%;max-width:220px;
  background:#1a1916;border-radius:8px;
  border:1px solid rgba(255,255,255,.07);
  overflow:hidden;
  box-shadow:0 20px 60px rgba(0,0,0,.5);
}
.mock-bar{
  background:#141311;padding:.5rem .7rem;
  display:flex;align-items:center;gap:.4rem;
  border-bottom:1px solid rgba(255,255,255,.05);
}
.mock-dot{width:6px;height:6px;border-radius:50%}
.mock-dot.r{background:#ff5f57}.mock-dot.y{background:#ffbd2e}.mock-dot.g{background:#28c840}
.mock-url{flex:1;background:#0e0d0c;border-radius:3px;height:14px;margin-left:.4rem;display:flex;align-items:center;padding:0 .5rem}
.mock-url span{font-family:var(--body);font-size:.42rem;color:rgba(255,255,255,.25);letter-spacing:.03em}
.mock-body{padding:.8rem}
.mock-hero-img{width:100%;height:60px;background:linear-gradient(135deg,rgba(58,90,255,.15),rgba(0,0,0,0));border-radius:4px;margin-bottom:.5rem;display:flex;align-items:center;justify-content:center}
.mock-hero-img span{font-family:var(--italic);font-style:italic;font-size:.7rem;color:rgba(255,255,255,.18)}
.mock-stars{display:flex;gap:2px;margin-bottom:.4rem}
.mock-star{color:#f5a623;font-size:.55rem}
.mock-lines{display:flex;flex-direction:column;gap:4px}
.mock-line{height:4px;background:rgba(255,255,255,.07);border-radius:2px}
.mock-line.w80{width:80%}.mock-line.w60{width:60%}.mock-line.w70{width:70%}

/* card 2 visual: inbox / notifications */
.mock-inbox{width:100%;max-width:220px;display:flex;flex-direction:column;gap:6px}
.mock-notif{
  background:#1a1916;border-radius:8px;
  border:1px solid rgba(255,255,255,.06);
  padding:.6rem .8rem;
  display:flex;align-items:center;gap:.7rem;
  box-shadow:0 4px 20px rgba(0,0,0,.3);
  transform:translateX(0);
  animation:none;
}
.mock-notif:nth-child(1){animation:slidein 4s 0s ease-in-out infinite alternate}
.mock-notif:nth-child(2){animation:slidein 4s .4s ease-in-out infinite alternate}
.mock-notif:nth-child(3){animation:slidein 4s .8s ease-in-out infinite alternate}
@keyframes slidein{0%{transform:translateX(6px);opacity:.7}100%{transform:translateX(0);opacity:1}}
.mock-notif-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0}
.nd-g{background:#4CAF50}.nd-b{background:#3a5aff}.nd-y{background:var(--acid)}
.mock-notif-text{display:flex;flex-direction:column;gap:2px}
.mock-notif-title{font-family:var(--display);font-size:.5rem;font-weight:600;letter-spacing:.05em;color:rgba(244,242,236,.7)}
.mock-notif-sub{font-size:.44rem;color:rgba(244,242,236,.3);font-family:var(--body)}

/* card 3 visual: folder / file structure */
.mock-files{width:100%;max-width:220px}
.mock-folder{
  background:#1a1916;border-radius:8px;
  border:1px solid rgba(255,255,255,.06);
  padding:.7rem .9rem;
  box-shadow:0 4px 20px rgba(0,0,0,.3);
}
.mock-folder-head{display:flex;align-items:center;gap:.5rem;margin-bottom:.6rem}
.folder-icon{font-size:.7rem}
.mock-folder-title{font-family:var(--display);font-size:.52rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:rgba(244,242,236,.5)}
.mock-file{display:flex;align-items:center;gap:.5rem;padding:.3rem 0;border-top:1px solid rgba(255,255,255,.04)}
.file-icon{font-size:.6rem;opacity:.5}
.file-name{font-family:var(--body);font-size:.48rem;color:rgba(244,242,236,.35);letter-spacing:.03em}
.file-tag{margin-left:auto;font-family:var(--display);font-size:.4rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;background:rgba(202,255,0,.15);color:var(--acid);padding:.15rem .4rem;border-radius:2px}
.file-tag.new{background:rgba(202,255,0,.2)}

/* card bottom text */
.ben-text-block{
  position:relative;z-index:3;
  padding:1.5rem 2rem 2rem;
  border-top:1px solid rgba(255,255,255,.05);
}
.ben-title{font-family:var(--display);font-size:1rem;font-weight:700;text-transform:uppercase;letter-spacing:-.01em;color:rgba(244,242,236,.9);margin-bottom:.45rem}
.ben-desc{font-size:.82rem;font-weight:300;line-height:1.7;color:rgba(244,242,236,.38)}

/* ── PORTFOLIO ── */
.portfolio{background:var(--blk2)}
.portfolio .s-h{color:var(--w)}
.portfolio .s-h em{color:rgba(244,242,236,.3)}
.portfolio .s-tag{color:rgba(244,242,236,.28)}
.portfolio .s-tag::before{background:var(--acid)}
.port-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:3px;margin-top:4rem}
.port-item{position:relative;overflow:hidden;aspect-ratio:16/10;cursor:none;background:var(--blk)}
.port-item.wide{grid-column:span 2;aspect-ratio:16/7}
.port-img{width:100%;height:100%;object-fit:cover;display:block;filter:saturate(.7) brightness(.85);transition:transform .75s cubic-bezier(.25,.46,.45,.94),filter .75s}
.port-item:hover .port-img{transform:scale(1.04);filter:saturate(1) brightness(.7)}
.port-over{position:absolute;inset:0;background:linear-gradient(to top,rgba(17,17,16,.85) 0%,transparent 55%);display:flex;flex-direction:column;justify-content:flex-end;padding:2rem 2.2rem}
.port-cat{font-family:var(--display);font-size:.52rem;font-weight:700;letter-spacing:.22em;text-transform:uppercase;color:var(--acid);margin-bottom:.4rem}
.port-name{font-family:var(--display);font-size:1.3rem;font-weight:800;text-transform:uppercase;letter-spacing:-.02em;color:var(--w);margin-bottom:.3rem}
.port-desc{font-size:.78rem;font-weight:300;color:rgba(244,242,236,.5);transform:translateY(6px);opacity:0;transition:transform .3s,opacity .3s}
.port-item:hover .port-desc{transform:none;opacity:1}
.p1{background:linear-gradient(135deg,#1a0f0f,#2d1515)}
.p2{background:linear-gradient(135deg,#0f1a12,#152d1a)}
.p3{background:linear-gradient(135deg,#0f0f1a,#15152d)}

/* ── SERVICES ACCORDION ── */
.services{background:var(--w)}
.accord-wrap{margin-top:4rem}
.accord-item{border-top:1px solid rgba(17,17,16,.08);overflow:hidden}
.accord-item:last-child{border-bottom:1px solid rgba(17,17,16,.08)}
.accord-head{display:grid;grid-template-columns:60px 1fr auto 44px;align-items:center;gap:2rem;padding:1.6rem 0;cursor:none}
.accord-n{font-family:var(--display);font-size:.55rem;font-weight:700;letter-spacing:.25em;text-transform:uppercase;color:var(--w3)}
.accord-title{font-family:var(--display);font-size:clamp(1.2rem,2.5vw,1.9rem);font-weight:800;text-transform:uppercase;letter-spacing:-.02em;color:var(--blk);transition:color .2s}
.accord-tags{display:flex;gap:.5rem;flex-wrap:wrap;justify-content:flex-end}
.accord-tag{font-family:var(--display);font-size:.46rem;font-weight:600;letter-spacing:.16em;text-transform:uppercase;color:var(--grey);border:1px solid var(--w3);padding:.22rem .55rem}
.accord-item.open .accord-tag{border-color:rgba(17,17,16,.2);color:var(--blk)}
.accord-arrow{width:36px;height:36px;border:1px solid rgba(17,17,16,.15);border-radius:50%;display:flex;align-items:center;justify-content:center;color:var(--blk);font-size:.9rem;transition:transform .4s cubic-bezier(.16,1,.3,1),background .25s,border-color .25s;flex-shrink:0}
.accord-item.open .accord-arrow{transform:rotate(45deg);background:var(--blk);color:var(--acid);border-color:var(--blk)}
.accord-body{height:0;overflow:hidden;transition:height .5s cubic-bezier(.16,1,.3,1)}
.accord-inner{display:grid;grid-template-columns:60px 1fr 1fr;gap:2.5rem;padding-bottom:2.5rem}
.accord-desc{font-size:.9rem;font-weight:300;line-height:1.85;color:var(--grey)}
.accord-list{list-style:none;display:flex;flex-direction:column;gap:.45rem}
.accord-list li{font-family:var(--display);font-size:.58rem;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:var(--grey);display:flex;align-items:center;gap:.6rem}
.accord-list li::before{content:'→';color:var(--blk);opacity:.4}

/* ── WHY ── */
.why-grid{display:grid;grid-template-columns:1fr 1fr;gap:0}
.why-h{font-family:var(--display);font-size:clamp(2.2rem,4vw,3.8rem);font-weight:800;text-transform:uppercase;letter-spacing:-.03em;line-height:.93;margin-bottom:1.8rem}
.why-intro{font-size:.95rem;font-weight:300;line-height:1.85;color:var(--grey);margin-bottom:3rem}
.why-pt{padding:1.4rem 0;border-top:1px solid rgba(17,17,16,.07);display:grid;grid-template-columns:32px 1fr;gap:1rem;align-items:start}
.why-pt:last-child{border-bottom:1px solid rgba(17,17,16,.07)}
.why-pt-n{font-family:var(--display);font-size:.52rem;font-weight:700;letter-spacing:.15em;color:var(--acid);background:var(--blk);width:26px;height:26px;display:flex;align-items:center;justify-content:center;margin-top:.1rem;flex-shrink:0}
.why-pt-title{font-family:var(--display);font-size:.8rem;font-weight:700;text-transform:uppercase;letter-spacing:.03em;color:var(--blk);margin-bottom:.35rem}
.why-pt-text{font-size:.83rem;font-weight:300;line-height:1.75;color:var(--grey)}
.why-metrics{display:flex;flex-direction:column;gap:0}
.why-metric{padding:2.2rem 0;border-top:1px solid rgba(17,17,16,.07)}
.why-metric:last-child{border-bottom:1px solid rgba(17,17,16,.07)}
.why-metric-n{font-family:var(--display);font-size:clamp(3rem,7vw,5.5rem);font-weight:800;letter-spacing:-.04em;line-height:1;color:var(--blk);margin-bottom:.35rem}
.why-metric-n .unit{font-size:.4em;font-weight:400;color:var(--grey)}
.why-metric-label{font-size:.83rem;font-weight:300;line-height:1.6;color:var(--grey)}
.why-metric-label strong{color:var(--blk);font-weight:500}

/* ── PRICING ── */
.pricing{background:var(--blk)}
.pricing .s-h{color:var(--w)}
.pricing .s-h em{color:var(--acid)}
.pricing .s-tag{color:rgba(244,242,236,.28)}
.pricing .s-tag::before{background:var(--acid)}
.pricing-sub{font-size:.88rem;font-weight:300;color:rgba(244,242,236,.38);margin-bottom:4rem;max-width:500px;margin-top:.6rem}
.p-table{width:100%;border-collapse:collapse}
.p-table th{font-family:var(--display);font-size:.5rem;font-weight:700;letter-spacing:.22em;text-transform:uppercase;color:rgba(244,242,236,.18);text-align:left;padding:.8rem 1.5rem;border-bottom:1px solid rgba(244,242,236,.06)}
.p-table th:first-child{padding-left:0}
.p-table td{padding:1.5rem 1.5rem;border-bottom:1px solid rgba(244,242,236,.04);vertical-align:top}
.p-table td:first-child{padding-left:0}
.p-table tr:hover td{background:rgba(244,242,236,.02)}
.p-table tr.featured td{background:rgba(202,255,0,.03)}
.p-tier{font-family:var(--display);font-size:.5rem;font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:var(--acid);display:block;margin-bottom:.3rem}
.p-name{font-family:var(--display);font-size:1.2rem;font-weight:800;text-transform:uppercase;letter-spacing:-.01em;color:var(--w)}
.p-price{font-family:var(--display);font-size:1.8rem;font-weight:800;letter-spacing:-.03em;color:var(--w);white-space:nowrap}
.p-price span{font-size:.55em;font-weight:300;color:rgba(244,242,236,.28)}
.p-sub{font-size:.68rem;color:rgba(244,242,236,.18);font-family:var(--display);letter-spacing:.06em;margin-top:.3rem}
.p-feats ul{list-style:none}
.p-feats li{font-size:.8rem;font-weight:300;color:rgba(244,242,236,.42);padding:.2rem 0;display:flex;gap:.5rem;align-items:flex-start}
.p-feats li::before{content:'✓';color:var(--acid);font-weight:700;font-size:.7rem;flex-shrink:0;margin-top:.1rem}
.p-cta-cell{vertical-align:middle!important}
.p-btn{font-family:var(--display);font-size:.55rem;font-weight:700;letter-spacing:.2em;text-transform:uppercase;background:transparent;color:rgba(244,242,236,.4);border:1px solid rgba(244,242,236,.1);padding:.7rem 1.2rem;text-decoration:none;cursor:none;display:inline-block;white-space:nowrap;transition:background .2s,color .2s,border-color .2s}
.p-btn:hover,.featured .p-btn{background:var(--acid);color:var(--blk);border-color:var(--acid)}
.featured .p-btn:hover{background:var(--acid2)}

/* ── CTA ── */
.cta-s{background:var(--w);padding:10rem 0;position:relative;overflow:hidden}
.cta-bg-word{position:absolute;bottom:-4rem;right:-2rem;font-family:var(--display);font-size:clamp(8rem,22vw,20rem);font-weight:800;text-transform:uppercase;letter-spacing:-.04em;color:transparent;-webkit-text-stroke:1px rgba(17,17,16,.05);pointer-events:none;user-select:none;line-height:1}
.cta-inner{max-width:1280px;margin:0 auto;padding:0 2.5rem;position:relative;z-index:1}
.cta-h{font-family:var(--display);font-size:clamp(2.8rem,7vw,7rem);font-weight:800;text-transform:uppercase;letter-spacing:-.04em;line-height:.9;color:var(--blk);margin-bottom:3rem}
.cta-h em{font-family:var(--italic);font-style:italic;text-transform:none;font-weight:400;font-size:.68em;letter-spacing:-.01em;color:var(--grey);display:block;margin-top:.15em}
.cta-acts{display:flex;align-items:center;gap:1.5rem;flex-wrap:wrap}

/* ── FOOTER ── */
footer{background:var(--blk);padding:4rem 0 3rem}
.f-inner{max-width:1280px;margin:0 auto;padding:0 2.5rem}
.f-grid{display:grid;grid-template-columns:1.5fr 1fr 1fr;gap:3rem;padding-bottom:3rem;border-bottom:1px solid rgba(244,242,236,.06)}
.f-logo{font-family:var(--display);font-size:.75rem;font-weight:800;letter-spacing:.1em;text-transform:uppercase;color:var(--w);text-decoration:none;display:flex;align-items:center;gap:.5rem;margin-bottom:.8rem}
.f-logo-dot{width:8px;height:8px;background:var(--acid);border-radius:50%}
.f-desc{font-size:.82rem;font-weight:300;color:rgba(244,242,236,.28);line-height:1.75;max-width:260px}
.f-ct{font-family:var(--display);font-size:.5rem;font-weight:700;letter-spacing:.25em;text-transform:uppercase;color:rgba(244,242,236,.18);margin-bottom:1rem}
.f-lk{list-style:none;display:flex;flex-direction:column;gap:.5rem}
.f-lk a{font-size:.82rem;font-weight:300;color:rgba(244,242,236,.38);text-decoration:none;cursor:none;transition:color .2s}
.f-lk a:hover{color:var(--acid)}
.f-bot{display:flex;justify-content:space-between;align-items:center;padding-top:2rem;flex-wrap:wrap;gap:1rem}
.f-copy{font-family:var(--display);font-size:.5rem;font-weight:600;letter-spacing:.2em;text-transform:uppercase;color:rgba(244,242,236,.16)}

/* ── REVEAL ── */
.rv{opacity:0;transform:translateY(20px);transition:opacity .65s,transform .65s}
.rv.on{opacity:1;transform:none}
.rv.d1{transition-delay:.1s}.rv.d2{transition-delay:.2s}.rv.d3{transition-delay:.3s}

@keyframes ain{from{opacity:0;transform:translateY(14px)}to{opacity:1;transform:none}}
@keyframes up{to{transform:translateY(0)}}
</style>
