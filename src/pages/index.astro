<script>

/* ── CURSOR ── */
const cd=document.getElementById('cd'),cr=document.getElementById('cr');
let mx=0,my=0,rx=0,ry=0;
document.addEventListener('mousemove',e=>{mx=e.clientX;my=e.clientY;cd.style.left=mx+'px';cd.style.top=my+'px'});
(function loop(){rx+=(mx-rx)*.1;ry+=(my-ry)*.1;cr.style.left=rx+'px';cr.style.top=ry+'px';requestAnimationFrame(loop)})();
document.addEventListener('mousemove',()=>{
  const els=document.elementsFromPoint(mx,my);
  document.body.classList.toggle('on-dark',els.some(el=>el.closest('[data-dark]')));
});
document.querySelectorAll('p,h1,h2,h3,li,td').forEach(el=>{el.addEventListener('mouseenter',()=>document.body.classList.add('ch'));el.addEventListener('mouseleave',()=>document.body.classList.remove('ch'))});
document.querySelectorAll('a,button,[data-accord] .accord-head').forEach(el=>{el.addEventListener('mouseenter',()=>{document.body.classList.remove('ch');document.body.classList.add('cl')});el.addEventListener('mouseleave',()=>document.body.classList.remove('cl'))});

/* ── LENIS ── */
if(typeof Lenis!=='undefined'){
  const l=new Lenis({duration:1.15,easing:t=>Math.min(1,1.001-Math.pow(2,-10*t)),smoothWheel:true});
  function raf(t){l.raf(t);requestAnimationFrame(raf)}
  requestAnimationFrame(raf);
  document.querySelectorAll('a[href^="#"]').forEach(a=>{a.addEventListener('click',e=>{e.preventDefault();const t=document.querySelector(a.getAttribute('href'));if(t)l.scrollTo(t,{offset:-80,duration:1.4})})});
}

/* ── NAV ── */
window.addEventListener('scroll',()=>document.getElementById('nav').classList.toggle('sc',window.scrollY>60),{passive:true});

/* ── ACCORDION (smooth pixel height) ── */
document.querySelectorAll('[data-accord]').forEach(item=>{
  item.querySelector('.accord-head').addEventListener('click',()=>{
    const isOpen=item.classList.contains('open');
    document.querySelectorAll('[data-accord].open').forEach(o=>{o.classList.remove('open');o.querySelector('.accord-body').style.height='0px'});
    if(!isOpen){item.classList.add('open');item.querySelector('.accord-body').style.height=item.querySelector('.accord-inner').offsetHeight+'px'}
  });
});

/* ── REVEAL ── */
const obs=new IntersectionObserver(es=>{es.forEach(e=>{if(e.isIntersecting){e.target.classList.add('on');obs.unobserve(e.target)}})},{threshold:.07});
document.querySelectorAll('.rv').forEach(el=>obs.observe(el));

/* ── COUNT UP ── */
function countUp(el,target){let s=null;(function step(ts){if(!s)s=ts;const p=Math.min((ts-s)/1200,1);el.textContent=Math.round((1-Math.pow(1-p,3))*target);if(p<1)requestAnimationFrame(step)})(performance.now())}
const cobs=new IntersectionObserver(es=>{es.forEach(e=>{if(e.isIntersecting){countUp(e.target,parseInt(e.target.dataset.count));cobs.unobserve(e.target)}})},{threshold:.5});
document.querySelectorAll('[data-count]').forEach(el=>cobs.observe(el));

document.getElementById('yr').textContent=new Date().getFullYear();
</script>
</body>
</html>